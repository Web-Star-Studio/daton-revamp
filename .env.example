# Local development defaults to local Postgres.
# Use an explicit DATABASE_URL override in your shell for one-off remote commands.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/daton
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000
INTERNAL_API_URL=http://127.0.0.1:8787
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=1
CORS_ORIGIN=http://127.0.0.1:3000
COOKIE_DOMAIN=
ALLOW_FICTIONAL_CNPJ=true
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_AUTHKIT_DOMAIN=
DATON_SESSION_SECRET=replace-with-at-least-32-characters
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=daton
